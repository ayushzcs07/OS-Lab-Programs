#include <stdio.h>

int main()
{
    int n, m, i, j, k;
    int a[10][10], req[10][10];
    int avail[10], f[10] = {0};
    int seq[10], c = 0, found;

    printf("Processes Resources: ");
    scanf("%d%d", &n, &m);

    printf("Allocation Matrix:\n");
    for(i = 0; i < n; i++)
        for(j = 0; j < m; j++)
            scanf("%d", &a[i][j]);

    printf("Request Matrix:\n");
    for(i = 0; i < n; i++)
        for(j = 0; j < m; j++)
            scanf("%d", &req[i][j]);

    printf("Available Resources:\n");
    for(i = 0; i < m; i++)
        scanf("%d", &avail[i]);

    while(c < n)
    {
        found = 0;

        for(i = 0; i < n; i++)
        {
            if(!f[i])
            {
                for(j = 0; j < m && req[i][j] <= avail[j]; j++);

                if(j == m)
                {
                    for(k = 0; k < m; k++)
                        avail[k] += a[i][k];

                    seq[c++] = i;
                    f[i] = 1;
                    found = 1;
                }
            }
        }

        if(!found)
            break;
    }

    if(c == n)
    {
        printf("\nNo Deadlock\n");
        printf("Sequence: ");

        for(i = 0; i < n; i++)
            printf("P%d ", seq[i]);
    }
    else
    {
        printf("\nDeadlock Detected\n");
    }

    return 0;
}
